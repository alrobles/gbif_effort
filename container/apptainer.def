Bootstrap: docker
From: rocker/geospatial:4.4.1

%labels
    Maintainer "Angel Luis Robles Fernández"
    Description "Geospatial R (rocker/geospatial:4.4.1) + gbifdb + ks + minioclient for GBIF KDE pipeline."

%environment
    CRAN=https://cloud.r-project.org
    LANG=en_US.UTF-8
    LC_ALL=en_US.UTF-8
    TZ=Etc/UTC

%post
    set -e
    echo "=== Installing required R packages (tidyverse & terra are in base) ==="
    R --quiet -e 'install.packages(c(
        "gbifdb",            # GBIF parquet interface
        "ks",                # KDE
        "minioclient",       # REQUIRED by gbifdb::gbif_download()
        "yaml","optparse",   # config / CLI
        "rnaturalearth","rnaturalearthdata", # land mask build
        "furrr"              # optional parallel mapping
      ), repos=Sys.getenv("CRAN"))'
    echo "=== Done installing R packages. ==="

%runscript
    # Usage: apptainer exec container/gbif-kde.sif <command>
    exec "$@"
