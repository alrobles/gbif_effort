Bootstrap: docker
From: rocker/geospatial:4.4.1

%labels
    Maintainer "Angel Luis Robles Fernández"
    Description "Geospatial R (rocker/geospatial:4.4.1) + gbifdb + ks + helpers for GBIF KDE pipeline."

%environment
    CRAN=https://cloud.r-project.org
    LANG=en_US.UTF-8
    LC_ALL=en_US.UTF-8
    TZ=Etc/UTC

%post
    set -e
    echo "=== Installing required R packages (tidyverse & terra already in base) ==="
    R --quiet -e 'install.packages(c("gbifdb","ks","yaml","optparse","rnaturalearth","rnaturalearthdata","furrr"), repos=Sys.getenv("CRAN"))'
    echo "=== Done. ==="

%runscript

